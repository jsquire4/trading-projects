# Solana RPC endpoint
# Default: devnet. Upgrade to Helius (https://helius.dev) for production reliability.
SOLANA_RPC_URL=https://api.devnet.solana.com

# Admin keypair (base58-encoded)
# Same as your Solana CLI default keypair (~/.config/solana/id.json).
# Used by scripts and services that submit admin instructions (initialize, settle, etc.)
ADMIN_KEYPAIR=base58_encoded_admin_keypair

# Frontend (Next.js public vars — must be prefixed with NEXT_PUBLIC_)
# For local validator: http://localhost:8899
NEXT_PUBLIC_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_USDC_MINT=mock_usdc_mint_pubkey
NEXT_PUBLIC_EVENT_INDEXER_URL=http://localhost:3001
NEXT_PUBLIC_DEFAULT_VOL=0.30

# Synthetic market data mode
# Set to "synthetic" to use generated data instead of Yahoo Finance.
# Enables development/testing when markets are closed.
# MARKET_DATA_SOURCE=synthetic
# SYNTHETIC_SEED=42

# AMM Bot configuration
BOT_QUANTITY=1000000
BOT_SPREAD_BPS=500
BOT_VOL=0.30
BOT_RISK_FREE_RATE=0.05

# Faucet (devnet only — separate keypair that holds mock USDC mint authority)
# This keypair cannot deploy programs or act as admin.
FAUCET_KEYPAIR=base58_encoded_faucet_keypair
