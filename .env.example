# Tradier API (brokerage account, GET-only access)
TRADIER_ACCOUNT=your_account_id_here
TRADIER_API_KEY=your_api_key_here

# Solana RPC (default devnet, upgrade to Helius for reliability)
SOLANA_RPC_URL=https://api.devnet.solana.com

# Frontend (public vars must be prefixed with NEXT_PUBLIC_)
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_USDC_MINT=your_devnet_mock_usdc_mint_here
