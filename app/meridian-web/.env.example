# Frontend environment variables for meridian-web (Next.js)
# Copy to .env.local and fill in values.

# Solana RPC endpoint (public — used in browser)
# For local validator: http://localhost:8899
NEXT_PUBLIC_RPC_URL=http://localhost:8899

# USDC mint address (must match what's deployed on your target cluster)
# For local validator: use the mock USDC mint created by scripts/create-mock-usdc.ts
NEXT_PUBLIC_USDC_MINT=mock_usdc_mint_pubkey

# Event indexer REST API base URL
NEXT_PUBLIC_EVENT_INDEXER_URL=http://localhost:3001

# Default implied volatility for AMM pricing (30%)
NEXT_PUBLIC_DEFAULT_VOL=0.30

# Solana network label (informational — actual cluster is inferred from RPC URL)
# Options: mainnet-beta, devnet, localnet
NEXT_PUBLIC_SOLANA_NETWORK=localnet

# Synthetic market data mode (uncomment to enable)
# MARKET_DATA_SOURCE=synthetic
# NEXT_PUBLIC_MARKET_DATA_SOURCE=synthetic
# SYNTHETIC_SEED=42
# NEXT_PUBLIC_MARKET_INIT_TRIGGER_URL=http://localhost:4001/trigger
# NEXT_PUBLIC_SETTLEMENT_TRIGGER_URL=http://localhost:4002/trigger

# Admin keypair JSON array (server-side only — used by USDC faucet to mint test tokens)
# Only needed on devnet/localnet. Example: [1,2,3,...,64]
ADMIN_KEYPAIR=
